[sqlfluff]

dialect = bigquery
sql_file_exts = .sql,.sql.j2,.dml,.ddl,.bqsql

# Tells it to ignore templates if you write raw SQL
templater = raw

# Optional: Max line length for formatting
max_line_length = 120

[sqlfluff:indentation]
tab_space_size = 2
indented_joins = False
indented_using_on = True
