config {
	type: "assertion",
	database: "automated-predictive-pipeline",
	schema: "published_dateset"
}

/*
	Exlucded expected columns that may contain nulls: 
	avg_fulfillment_days, cancellation_count, returned_count
*/

SELECT *
FROM ${ref("logistic_impact")}
WHERE order_date IS NULL
	OR	dc_name IS NULL
	OR	product_category IS NULL