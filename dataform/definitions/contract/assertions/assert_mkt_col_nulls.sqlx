config {
  type: "assertion",
  database: "automated-predictive-pipeline",
  schema: "contracted_dataset"
}

SELECT *
FROM ${ref("marketing_data")}
WHERE campaign_id IS NULL
  OR  campaign_date IS NULL
  OR  campaign_name IS NULL
  OR  canonical_traffic_source IS NULL
  OR  target_category IS NULL
  OR  spend_usd IS NULL